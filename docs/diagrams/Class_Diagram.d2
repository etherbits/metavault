direction: down

User: {
  shape: class
  "- id": UUID
  "- username": string
  "- email": string
  "- createdAt": DateTime
  "+ getUsername()": string
  "+ getEmail()": string
  "+ login()": Token
  "+ updateProfile(data)": void
  "+ exportLibrary()": JSON
}

Collection: {
  shape: class
  "- id": UUID
  "- userId": UUID
  "- name": string
  "- description": string
  "- createdAt": DateTime
  "+ getName()": string
  "+ addEntry(entry)": void
  "+ removeEntry(entryId)": void
  "+ getEntries()": "LibraryEntry[]"
}

EzqQuery: {
  shape: class
  "- raw": string
  "- ast": AST
  "- filters": FilterMap
  "- errors": "string[]"
  "+ parse()": AST
  "+ toSQL()": string
  "+ validate()": boolean
  "+ hasEnrichFlag()": boolean
  "+ getErrors()": "string[]"
}

AIIntegration: {
  shape: class
  "- model": string
  "- enabled": boolean
  "+ isEnabled()": boolean
  "+ setEnabled(val)": void
  "+ chat(messages)": string
  "+ suggest(entry)": "LibraryEntry[]"
}

LibraryEntry: {
  shape: class
  "- id": UUID
  "- userId": UUID
  "- mediaId": string
  "- sourceId": SourceType
  "- mediaType": MediaType
  "- status": WatchStatus
  "- progress": int
  "- rating": "float | null"
  "- review": "string | null"
  "- startedAt": "DateTime | null"
  "- completedAt": "DateTime | null"
  "- updatedAt": DateTime
  "+ getStatus()": WatchStatus
  "+ updateStatus(s)": void
  "+ setRating(r)": void
  "+ setReview(r)": void
  "+ getProgress()": int
  "+ setProgress(n)": void
}

SourceType: {
  shape: class
  "<<enum>>"
  TMDB: ""
  ANILIST: ""
  IGDB: ""
  OPENLIBRARY: ""
}

MediaType: {
  shape: class
  "<<enum>>"
  MOVIE: ""
  TV: ""
  ANIME: ""
  MANGA: ""
  GAME: ""
  BOOK: ""
}

WatchStatus: {
  shape: class
  "<<enum>>"
  PLANNING: ""
  IN_PROGRESS: ""
  COMPLETED: ""
  DROPPED: ""
  PAUSED: ""
}

ISourceIntegration: {
  shape: class
  "<<interface>>"
  "+ search(query)": "MediaResult[]"
  "+ fetchMetadata(mediaId)": MediaMetadata
  "+ enrich(entry)": LibraryEntry
  "+ getSourceType()": SourceType
}

TMDBIntegration: {
  shape: class
  "- baseUrl": string
  "+ search(query)": "MediaResult[]"
  "+ fetchMetadata(mediaId)": MediaMetadata
  "+ enrich(entry)": LibraryEntry
  "+ getSourceType()": SourceType
}

AniListIntegration: {
  shape: class
  "- baseUrl": string
  "+ search(query)": "MediaResult[]"
  "+ fetchMetadata(mediaId)": MediaMetadata
  "+ enrich(entry)": LibraryEntry
  "+ getSourceType()": SourceType
}

IGDBIntegration: {
  shape: class
  "- baseUrl": string
  "+ search(query)": "MediaResult[]"
  "+ fetchMetadata(mediaId)": MediaMetadata
  "+ enrich(entry)": LibraryEntry
  "+ getSourceType()": SourceType
}

OpenLibraryIntegration: {
  shape: class
  "- baseUrl": string
  "+ search(query)": "MediaResult[]"
  "+ fetchMetadata(mediaId)": MediaMetadata
  "+ enrich(entry)": LibraryEntry
  "+ getSourceType()": SourceType
}

User -> LibraryEntry: "1..* owns"
User -> Collection: "1..* has"
User -> EzqQuery: issues
User -> AIIntegration: uses
Collection -> LibraryEntry: "* contains"
EzqQuery -> LibraryEntry: queries
LibraryEntry -> SourceType: uses
LibraryEntry -> MediaType: has
LibraryEntry -> WatchStatus: has
LibraryEntry -> ISourceIntegration: "enriched via"
TMDBIntegration -> ISourceIntegration: implements
AniListIntegration -> ISourceIntegration: implements
IGDBIntegration -> ISourceIntegration: implements
OpenLibraryIntegration -> ISourceIntegration: implements
