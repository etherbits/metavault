{
  "name": "core",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "format": "bunx @biomejs/biome format --write .",
    "lint": "bunx @biomejs/biome lint .",
    "lint:fix": "bunx @biomejs/biome lint --write .",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:unit": "bun test tests/unit-tests",
    "type-check": "bun run --cwd packages/server type-check && bun run --cwd packages/web-client type-check",
    "db:seed": "bun --cwd packages/server run db:seed",
    "db:reset": "bun --cwd packages/server run db:reset",
    "ezq:build": "wasm-pack build packages/ezq --target nodejs --out-dir out/node --scope ezq-node && wasm-pack build packages/ezq --target bundler --scope ezq-web --out-dir out/web"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "lefthook": "^2.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "workspaces": [
    "packages/ezq/out/node",
    "packages/ezq/out/web",
    "packages/server",
    "packages/web-client",
    "tests"
  ]
}
